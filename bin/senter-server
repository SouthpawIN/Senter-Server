#!/bin/bash
# Senter Server - Unified Model Manager
# Manages all multimodal models with smart VRAM switching
# Supports: PEAK (9 models), HIGH (7), MEDIUM (5), BASIC (3), CPU (2)
#
# Usage: senter-server {start|stop|status|restart} [model_name]
#        senter-server start-all
#        senter-server vram-usage

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${HOME}/.senter-server/config/server.conf"
LOG_DIR="${HOME}/.senter-server/logs"
MODELS_DIR="/home/sovthpaw/Models/storage/gguf"
BIN_DIR="$SCRIPT_DIR"

# Default ports (can be overridden in config)
PORT_LLM=8100
PORT_IMAGE=8108
PORT_IMAGE_EDIT=8109
PORT_TTS=8102
PORT_ACESTEP=8106
PORT_LTX=8105
PORT_EMBED=8107

# Load configuration if exists
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# Set paths from config or use defaults
MODELS_DIR="${MODELS_DIR:-$HOME/.senter-server/models}"
LOG_DIR="${LOG_DIR:-/tmp/senter-logs}"
BIN_DIR="${BIN_DIR:-/home/sovthpaw/Senter-Server/bin}"
TAILSCALE_IP="${TAILSCALE_IP:-100.84.195.22}"

# Ensure directories exist
mkdir -p "$LOG_DIR"

# Export library path for llama.cpp
export LD_LIBRARY_PATH="$BIN_DIR:$LD_LIBRARY_PATH"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${BLUE}[Senter-Server]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

# Check if API endpoint is responding
model_running() {
    local port=$1
    curl -s --connect-timeout 2 "http://localhost:$port/v1/models" >/dev/null 2>&1
}

service_running() {
    local port=$1
    local path=${2:-/}
    curl -s --connect-timeout 2 "http://localhost:$port$path" >/dev/null 2>&1
}

# Get current model name from API
get_current_model() {
    curl -s "http://localhost:$PORT_LLM/v1/models" 2>/dev/null | \
        python3 -c "import sys,json; print(json.load(sys.stdin)['data'][0]['id'])" 2>/dev/null || echo ""
}

# Get VRAM usage
get_vram_usage() {
    if command -v nvidia-smi >/dev/null 2>&1; then
        nvidia-smi --query-gpu=name,memory.total,memory.used,memory.free --format=csv,noheader,nounits | while read line; do
            echo "  $line"
        done
    else
        warn "nvidia-smi not found - cannot check VRAM (CPU-only mode?)"
    fi
}

# Start Qwen3.5-35B-A3B with 1M context (YaRN scaling)
start_qwen35_1m() {
    log "Starting Qwen3.5-35B-A3B with 1M context..."
    
    local model_path="$MODELS_DIR/Qwen3.5-35B-A3B-GGUF/Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf"
    
    if [ ! -f "$model_path" ]; then
        error "Model not found: $model_path"
        error "Run: ./scripts/download-models.sh peak"
        return 1
    fi
    
    # Kill any existing process on this port
    fuser -k $PORT_LLM/tcp 2>/dev/null || true
    sleep 1
    
    nohup $BIN_DIR/llama-server \
        --model "$model_path" \
        --alias qwen3.5-35b-a3b-1m \
        --ctx-size 1010000 \
        --n-gpu-layers -1 \
        --cache-type-k q4_0 \
        --cache-type-v q4_0 \
        --rope-scaling yarn \
        --rope-scale 4.0 \
        --yarn-orig-ctx 262144 \
        --flash-attn on \
        --threads 16 \
        --port $PORT_LLM \
        --host 0.0.0.0 \
        --jinja \
        --temp 0.7 \
        --top-p 0.95 \
        --repeat-penalty 1.0 \
        -np 1 -b 512 -ub 256 \
        --top-k 20 \
        --presence-penalty 1.5 \
        > "$LOG_DIR/qwen35-1m.log" 2>&1 &
    
    local pid=$!
    echo $pid > /tmp/senter-qwen35-1m.pid
    
    log "PID: $pid"
    
    # Wait for startup (up to 60 seconds)
    for i in {1..60}; do
        if model_running $PORT_LLM; then
            success "Qwen3.5-35B-A3B 1M context is ready!"
            echo "  Local: http://localhost:$PORT_LLM/v1"
            echo "  TailScale: http://$TAILSCALE_IP:$PORT_LLM/v1"
            return 0
        fi
        sleep 1
    done
    
    error "Failed to start - check $LOG_DIR/qwen35-1m.log"
    return 1
}

# Start Qwen3.5-35B-A3B standard (262K context)
start_qwen35() {
    log "Starting Qwen3.5-35B-A3B (~80 tok/s)..."
    
    local model_path="$MODELS_DIR/Qwen3.5-35B-A3B-GGUF/Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf"
    
    if [ ! -f "$model_path" ]; then
        error "Model not found: $model_path"
        return 1
    fi
    
    fuser -k $PORT_LLM/tcp 2>/dev/null || true
    sleep 1
    
    nohup $BIN_DIR/llama-server \
        --model "$model_path" \
        --alias qwen3.5-35b-a3b \
        --ctx-size 262144 \
        --n-gpu-layers -1 \
        --cache-type-k q8_0 \
        --cache-type-v q8_0 \
        --flash-attn on \
        --threads 10 \
        --port $PORT_LLM \
        --host 0.0.0.0 \
        --jinja \
        --temp 0.7 \
        --top-p 0.95 \
        --repeat-penalty 1.0 \
        -np 1 -b 512 -ub 256 \
        --top-k 20 \
        --presence-penalty 1.5 \
        > "$LOG_DIR/qwen35.log" 2>&1 &
    
    log "PID: $!"
    
    for i in {1..60}; do
        if model_running $PORT_LLM; then
            success "Qwen3.5-35B-A3B is ready (~80 tok/s)!"
            echo "  Local: http://localhost:$PORT_LLM/v1"
            echo "  TailScale: http://$TAILSCALE_IP:$PORT_LLM/v1"
            return 0
        fi
        sleep 1
    done
    
    error "Failed to start - check $LOG_DIR/qwen35.log"
    return 1
}

